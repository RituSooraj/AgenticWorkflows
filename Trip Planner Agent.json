      "parameters": {
        "jsCode": "{\n  \"title\": \"TripPlannerRequest\",\n  \"type\": \"object\",\n  \"required\": [\"error\"],\n  \"properties\": {\n    \"origin\": {\n      \"type\": \"string\",\n      \"description\": \"City or airport code of departure\"\n    },\n    \"destination\": {\n      \"type\": \"string\",\n      \"description\": \"City or airport code of destination\"\n    },\n    \"departure_date\": {\n      \"type\": \"string\",\n      \"format\": \"date\",\n      \"description\": \"Departure date in YYYY-MM-DD\"\n    },\n    \"return_date\": {\n      \"type\": \"string\",\n      \"format\": \"date\",\n      \"description\": \"Return date in YYYY-MM-DD\"\n    },\n    \"error\": {\n      \"type\": \"boolean\",\n      \"default\": false,\n      \"description\": \"Return true if one of origin, destination, departure_date, return_date fields are either empty or not filled in\"\n    },\n    \"error_msg\": {\n      \"type\": \"string\",\n      \"default\": \"\",\n      \"description\": \"Include the error message and list the missing fields\"\n    },\n    \"number_of_travelers\": {\n      \"type\": \"integer\",\n      \"minimum\": 1,\n      \"default\": 1\n    },\n    \"budget\": {\n      \"type\": \"number\",\n      \"description\": \"Total trip budget in USD\"\n    },\n    \"travel_style\": {\n      \"type\": \"string\",\n      \"enum\": [\"budget\", \"mid-range\", \"luxury\"]\n    },\n    \"preferences\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"string\"\n      },\n      \"description\": \"User interests such as food, museums, nightlife, hiking\"\n    },\n    \"hotel_preferences\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"star_rating_min\": {\n          \"type\": \"number\",\n          \"minimum\": 1,\n          \"maximum\": 5\n        },\n        \"neighborhood\": {\n          \"type\": \"string\"\n        }\n      }\n    },\n    \"flight_preferences\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"nonstop_only\": {\n          \"type\": \"boolean\"\n        },\n        \"preferred_airlines\": {\n          \"type\": \"array\",\n          \"items\": {\n            \"type\": \"string\"\n          }\n        }\n      }\n    }\n  }\n}"
